# Public URL used in messages and generated links.
PUBLIC_BASE_URL=https://download.example.com

# Cloudflare Access.
# When true, every /api and /download request must carry a valid Cloudflare
# Access JWT. The plaintext identity header is NEVER trusted on its own.
# Set to false ONLY for local development.
REQUIRE_CLOUDFLARE_ACCESS=true

# Required when REQUIRE_CLOUDFLARE_ACCESS=true.
# Team domain: "myteam" or "myteam.cloudflareaccess.com" (the JWT issuer).
CF_ACCESS_TEAM_DOMAIN=myteam
# Application Audience (AUD) tag from the Access application's settings.
CF_ACCESS_AUD=replace-with-access-application-aud-tag

# Redis connection shared by the app/API container and worker container.
REDIS_URL=redis://redis:6379

# Temporary media storage inside containers (a dedicated writable volume; the
# rest of the container filesystem is read-only).
TEMP_DIR=/data/media

# Job and cleanup limits.
MAX_GLOBAL_CONCURRENT_JOBS=2
MAX_CONCURRENT_JOBS_PER_USER=1
MAX_VIDEO_DURATION_SECONDS=7200
MAX_FILE_SIZE_BYTES=2147483648
JOB_EXPIRATION_SECONDS=900
CLEANUP_INTERVAL_SECONDS=60
INSPECT_TIMEOUT_MS=25000
# Hard wall-clock limit for a single download before yt-dlp is killed.
DOWNLOAD_TIMEOUT_MS=1200000

# Rate limits. Cloudflare should also protect the tunnel.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=1 minute

# Cloudflare Tunnel.
# Create a named tunnel in Cloudflare Zero Trust and place its token here.
CLOUDFLARED_TOKEN=replace-me
